# ===== Backend (apps/api) =====
# Copy to apps/api/.env

# Postgres connection string (local dev with Docker:
#   docker run --name electrozone-db -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=electrozone -p 5432:5432 -d postgres:16)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/electrozone?schema=public

# Origin of the frontend (CORS allowlist)
WEB_ORIGIN=http://localhost:5173

# Admin auth
ADMIN_PASSWORD=admin
ADMIN_API_KEY=dev-admin-key

# Gemini (optional — enables the real AI assistant; falls back to a rule-based bot if empty)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ===== Frontend (apps/web) =====
# Copy to apps/web/.env.local
# Only set this if the backend is NOT on the same origin (dev uses a Vite proxy by default)
# VITE_API_URL=http://localhost:4000/api